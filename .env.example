# Salin file ini jadi .env (jangan commit) lalu isi nilainya.
# Di runner FlazHost, env var di-inject otomatis dari App Settings → Environment Variables,
# jadi file .env hanya dipakai untuk local development.

# --- Aplikasi ---
APP_NAME="My PHP App"
APP_URL=http://localhost:8080

# --- Database (opsional — bisa di-link via runner / linked MySQL service) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=app_db
DB_USER=root
DB_PASS=secret
